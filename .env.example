# EmailJS Configuration
# Sign up at https://www.emailjs.com/ (free tier: 200 emails/month)
#
# Steps:
# 1. Create account at emailjs.com
# 2. Go to "Email Services" → Add Gmail or any service → Copy SERVICE ID
# 3. Go to "Email Templates" → Create template → Copy TEMPLATE ID
# 4. Go to "Account" → Copy PUBLIC KEY
# 5. Copy this file as .env and fill in the values

VITE_APP_EMAILJS_SERVICE_ID=your_service_id_here
VITE_APP_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_APP_EMAILJS_PUBLIC_KEY=your_public_key_here
